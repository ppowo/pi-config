{
  "theme": "github-light-colorblind",
  "spinnerVerbs": "random",
  "npmCommand": ["npm", "--legacy-peer-deps"],
  "packages": [
    {
      "source": "npm:pi-amplike",
      "extensions": [
        "extensions/handoff.ts",
        "extensions/session-query.ts"
      ],
      "skills": [
        "skills/session-query/SKILL.md"
      ]
    },
    "npm:pi-context-zone",
    "npm:pi-scurl",
    "npm:@pborck/pi-de",
    "npm:@marckrenn/pi-sub-bar",
    {
      "source": "npm:@aliou/pi-synthetic",
      "extensions": [
        "src/extensions/provider/index.ts",
        "src/extensions/sub-bar-integration/index.ts"
      ]
    },
    "npm:@tintinweb/pi-tasks",
    "npm:pi-verbosity-control",
    "npm:@aaronmaturen/pi-context7",
    "npm:@robhowley/spinner-verbs",
    "https://github.com/coctostan/pi-hashline-readmap",
    "extensions/bash-context-guard.ts",
    "npm:pi-system-reminders",
    "npm:pi-bash-bg",
    "npm:@coctostan/pi-exa-gh-web-tools",
    "https://github.com/mattpocock/skills"
  ],
  "skills": [
    "~/.pi/agent/git/github.com/mattpocock/skills/grill-me",
    "~/.pi/agent/git/github.com/mattpocock/skills/improve-codebase-architecture",
    "~/.pi/agent/git/github.com/mattpocock/skills/tdd",
    "~/.pi/agent/git/github.com/mattpocock/skills/ubiquitous-language"
  ],
  "extensions": [
    "extensions/bash-snapshot.ts",
    "extensions/handoff-lite.ts",
    "-extensions/bash-context-guard.ts"
  ],
  "compaction": {
    "enabled": false
  }
}